<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="145"
                android:startColor="#0D1B5E"
                android:centerColor="#1A237E"
                android:endColor="#283593" />
        </shape>
    </item>
    <item android:top="-80dp" android:right="-80dp" android:bottom="180dp" android:left="120dp">
        <shape android:shape="oval">
            <solid android:color="#1AFFFFFF" />
        </shape>
    </item>
    <item android:top="80dp" android:right="200dp" android:bottom="-50dp" android:left="-50dp">
        <shape android:shape="oval">
            <solid android:color="#0DFFFFFF" />
        </shape>
    </item>
</layer-list>
