<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="145"
                android:startColor="#0D1B5E"
                android:centerColor="#1A237E"
                android:endColor="#283593" />
        </shape>
    </item>

    <!-- Decorative circle top-right -->
    <item
        android:top="-120dp"
        android:right="-120dp"
        android:bottom="400dp"
        android:left="120dp">
        <shape android:shape="oval">
            <solid android:color="#1AFFFFFF" />
        </shape>
    </item>

    <!-- Decorative circle bottom-left -->
    <item
        android:top="300dp"
        android:right="200dp"
        android:bottom="-100dp"
        android:left="-80dp">
        <shape android:shape="oval">
            <solid android:color="#0DFFFFFF" />
        </shape>
    </item>

    <!-- Subtle overlay dots texture layer -->
    <item android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#00000000"
                android:endColor="#1A3949AB" />
        </shape>
    </item>

</layer-list>
