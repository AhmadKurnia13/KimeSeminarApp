<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kime_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══ Hero Header ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:background="@drawable/bg_result_success"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <!-- Success icon -->
            <FrameLayout
                android:layout_width="90dp"
                android:layout_height="90dp">
                <ImageView
                    android:id="@+id/ivSuccess"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:src="@drawable/ic_success"
                    android:contentDescription="Success" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvSuccessTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Pendaftaran Berhasil! 🎉"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvSuccessSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Cek email Anda untuk konfirmasi lebih lanjut"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:lineSpacingExtra="3dp" />

        </LinearLayout>

        <!-- ═══ Result Detail Card ═══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="-24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Card title row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <!-- Avatar circle -->
                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp">
                        <View
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_avatar_primary" />
                        <TextView
                            android:id="@+id/tvAvatarResult"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="?"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Detail Pendaftaran"
                            android:textColor="#1A237E"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Ringkasan data yang terdaftar"
                            android:textColor="#9898BB"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider line -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F0F2FF"
                    android:layout_marginBottom="16dp" />

                <!-- ─── Result rows ─── -->

                <!-- Nama -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_divider_item"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_person"
                        android:tint="#3F51B5"
                        android:contentDescription="Nama" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nama Lengkap"
                            android:textColor="#9898BB"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/tvNama"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="-"
                            android:textColor="#1A1A2E"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Email -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_divider_item"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_email"
                        android:tint="#3F51B5"
                        android:contentDescription="Email" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Email"
                            android:textColor="#9898BB"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/tvEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="-"
                            android:textColor="#1A1A2E"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- No HP -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_divider_item"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_phone"
                        android:tint="#3F51B5"
                        android:contentDescription="Phone" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nomor HP"
                            android:textColor="#9898BB"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/tvNoHp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="-"
                            android:textColor="#1A1A2E"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Jenis Kelamin -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_divider_item"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_person"
                        android:tint="#FF8F00"
                        android:contentDescription="Gender" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jenis Kelamin"
                            android:textColor="#9898BB"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/tvJenisKelamin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="-"
                            android:textColor="#1A1A2E"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Tanggal -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_divider_item"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_calendar"
                        android:tint="#3F51B5"
                        android:contentDescription="Date" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tanggal Masuk"
                            android:textColor="#9898BB"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/tvTanggal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="-"
                            android:textColor="#1A1A2E"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Versi Soal -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_divider_item"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_badge"
                        android:tint="#3F51B5"
                        android:contentDescription="Version" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Versi Soal"
                            android:textColor="#9898BB"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/tvVersiSoal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="-"
                            android:textColor="#1A1A2E"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Halaman -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_divider_item"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_school"
                        android:tint="#3F51B5"
                        android:contentDescription="Page" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Halaman"
                            android:textColor="#9898BB"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/tvHalaman"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="-"
                            android:textColor="#1A1A2E"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Seminar highlight row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#E8EAF6"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:layout_marginBottom="4dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_seminars"
                        android:tint="#1A237E"
                        android:contentDescription="Seminar" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Seminar Dipilih"
                            android:textColor="#3F51B5"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:id="@+id/tvSeminar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="-"
                            android:textColor="#1A237E"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:lineSpacingExtra="2dp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ Action Buttons ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackHome"
                style="@style/KimePrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:text="🏠  Kembali ke Beranda"
                android:letterSpacing="0.02" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDaftarLagi"
                style="@style/KimeOutlineButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="12dp"
                android:text="🎓  Daftar Seminar Lain" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
