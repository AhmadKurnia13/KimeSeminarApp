<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_login">

    <!-- Decorative bubbles -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:alpha="0.07"
        android:background="@drawable/bg_avatar_primary"
        android:layout_gravity="top|end"
        android:layout_marginTop="-70dp"
        android:layout_marginEnd="-70dp" />

    <View
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:alpha="0.05"
        android:background="@drawable/bg_avatar_primary"
        android:layout_gravity="top|start"
        android:layout_marginTop="120dp"
        android:layout_marginStart="-40dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/bg_gradient_login"
            android:elevation="0dp"
            app:navigationIconTint="@android:color/white" />

        <!-- Top area: illustration -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.35"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/ic_seminar_illustration"
                android:alpha="0.8"
                android:contentDescription="Forgot password illustration"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Reset Password"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Kami akan mengirimkan link reset ke email Anda"
                android:textColor="#99FFFFFF"
                android:textSize="12sp"
                android:gravity="center" />

        </LinearLayout>

        <!-- Bottom card: form -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.65"
            android:background="@drawable/bg_card_top_rounded"
            android:elevation="16dp">

            <!-- Success scrollview -->
            <ScrollView
                android:id="@+id/containerSuccess"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="28dp"
                    android:paddingEnd="28dp"
                    android:paddingTop="32dp"
                    android:paddingBottom="32dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_kime_logo"
                        android:tint="@color/kime_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Email Terkirim! ✅"
                        android:textColor="#1A237E"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Kami telah mengirimkan link reset password ke:"
                        android:textColor="#6B6B8A"
                        android:textSize="14sp"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/tvSuccessEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/kime_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="⏱️ Link akan berlaku selama 24 jam. Jangan lupa untuk cek folder SPAM jika email tidak muncul."
                        android:textColor="#6B6B8A"
                        android:textSize="13sp"
                        android:gravity="center" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBackToLogin"
                        style="@style/KimePrimaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/btn_height"
                        android:layout_marginTop="28dp"
                        android:text="KEMBALI KE LOGIN"
                        android:letterSpacing="0.08" />

                </LinearLayout>

            </ScrollView>

            <!-- Form scrollview -->
            <ScrollView
                android:id="@+id/containerForm"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="28dp"
                    android:paddingEnd="28dp"
                    android:paddingTop="32dp"
                    android:paddingBottom="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Masukkan Email Anda 📧"
                        android:textColor="#1A237E"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Kami akan mengirimkan link reset ke email Anda"
                        android:textColor="#6B6B8A"
                        android:textSize="13sp" />

                    <!-- Divider accent -->
                    <View
                        android:layout_width="40dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="12dp"
                        android:background="#FF8F00" />

                    <!-- Email field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEmail"
                        style="@style/KimeTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:hint="Email"
                        app:startIconDrawable="@drawable/ic_email"
                        app:startIconTint="@color/kime_primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:imeOptions="actionDone"
                            android:textSize="15sp"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Progress bar -->
                    <ProgressBar
                        android:id="@+id/progressReset"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_marginTop="8dp"
                        android:indeterminate="true"
                        android:indeterminateTint="@color/kime_primary"
                        android:visibility="gone" />

                    <!-- Send Reset Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSendReset"
                        style="@style/KimePrimaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/btn_height"
                        android:layout_marginTop="24dp"
                        android:text="KIRIM LINK RESET"
                        android:letterSpacing="0.08" />

                    <!-- Back to login -->
                    <TextView
                        android:id="@+id/tvBackToLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="20dp"
                        android:text="← Kembali ke Login"
                        android:textColor="@color/kime_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:padding="8dp" />

                </LinearLayout>

            </ScrollView>

        </FrameLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

