<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Seminar Title -->
        <TextView
            android:id="@+id/tvSeminarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/kime_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="Seminar Teknologi AI" />

        <!-- Registration Date -->
        <TextView
            android:id="@+id/tvRegistrationDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/gray"
            android:textSize="14sp"
            tools:text="Didaftar pada: 15 Desember 2023" />

        <!-- Seminar Details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/kime_primary" />

                <TextView
                    android:id="@+id/tvSeminarDateTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/kime_text_primary"
                    android:textSize="14sp"
                    tools:text="25 Des 2023, 10:00 - 12:00" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_school"
                    app:tint="@color/kime_primary" />

                <TextView
                    android:id="@+id/tvSeminarLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/kime_text_primary"
                    android:textSize="14sp"
                    tools:text="Auditorium Gedung A" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/kime_primary" />

                <TextView
                    android:id="@+id/tvSeminarSpeaker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/kime_text_primary"
                    android:textSize="14sp"
                    tools:text="Dr. Ahmad Kurnia" />

            </LinearLayout>

        </LinearLayout>

        <!-- Status Badge -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Terdaftar"
            app:chipBackgroundColor="@color/kime_primary"
            app:chipIcon="@drawable/ic_check_circle"
            app:chipIconTint="@color/white"
            app:chipStrokeWidth="0dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
