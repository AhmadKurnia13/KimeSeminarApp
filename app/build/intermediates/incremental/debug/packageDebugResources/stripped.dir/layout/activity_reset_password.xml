<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_login">

    <!-- Decorative bubbles -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:alpha="0.07"
        android:background="@drawable/bg_avatar_primary"
        android:layout_gravity="top|end"
        android:layout_marginTop="-70dp"
        android:layout_marginEnd="-70dp" />

    <View
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:alpha="0.05"
        android:background="@drawable/bg_avatar_primary"
        android:layout_gravity="top|start"
        android:layout_marginTop="120dp"
        android:layout_marginStart="-40dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/bg_gradient_login"
            android:elevation="0dp"
            app:navigationIconTint="@android:color/white" />

        <!-- Top area: illustration -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.32"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_seminar_illustration"
                android:alpha="0.8"
                android:contentDescription="Reset password illustration"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Password Baru"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Buatkan password baru yang kuat"
                android:textColor="#99FFFFFF"
                android:textSize="12sp"
                android:gravity="center" />

        </LinearLayout>

        <!-- Bottom card: form -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.68"
            android:background="@drawable/bg_card_top_rounded"
            android:fillViewport="true"
            android:elevation="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="28dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buat Password Baru 🔐"
                    android:textColor="#1A237E"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Pastikan password cukup kuat dan mudah diingat"
                    android:textColor="#6B6B8A"
                    android:textSize="13sp" />

                <!-- Divider accent -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="12dp"
                    android:background="#FF8F00" />

                <!-- New Password field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilNewPassword"
                    style="@style/KimeTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:hint="Password Baru"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="@color/kime_primary"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/kime_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNewPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="actionNext"
                        android:textSize="15sp"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Confirm Password field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilConfirmPassword"
                    style="@style/KimeTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Konfirmasi Password"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="@color/kime_primary"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/kime_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:textSize="15sp"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password strength indicator -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡 Tips Password Kuat:"
                        android:textColor="#1A237E"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="• Minimal 6 karakter\n• Gunakan huruf besar, kecil, dan angka\n• Hindari kata-kata pribadi"
                        android:textColor="#6B6B8A"
                        android:textSize="12sp"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>

                <!-- Progress bar -->
                <ProgressBar
                    android:id="@+id/progressReset"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="20dp"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/kime_primary"
                    android:visibility="gone" />

                <!-- Reset Password Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetPassword"
                    style="@style/KimePrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/btn_height"
                    android:layout_marginTop="24dp"
                    android:text="PERBARUI PASSWORD"
                    android:letterSpacing="0.08" />

                <!-- Back to login -->
                <TextView
                    android:id="@+id/tvBackToLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:text="← Kembali ke Login"
                    android:textColor="@color/kime_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:padding="8dp" />

            </LinearLayout>

        </ScrollView>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

