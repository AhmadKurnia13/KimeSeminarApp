<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_login">

    <!-- ═══════════════════════════════════
         TOP SECTION  —  gradient + logo
    ═══════════════════════════════════ -->

    <!-- Decorative bubbles -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:alpha="0.07"
        android:background="@drawable/bg_avatar_primary"
        android:layout_gravity="top|end"
        android:layout_marginTop="-70dp"
        android:layout_marginEnd="-70dp" />

    <View
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:alpha="0.05"
        android:background="@drawable/bg_avatar_primary"
        android:layout_gravity="top|start"
        android:layout_marginTop="120dp"
        android:layout_marginStart="-40dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top area: logo + welcome text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.42"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="24dp">

            <!-- Logo ring -->
            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_gravity="center">
                <View
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:background="@drawable/bg_logo_circle" />
                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_kime_logo"
                    android:contentDescription="Kime Logo" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="KIME SEMINAR"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.10" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Smart Registration Platform"
                android:textColor="#99FFFFFF"
                android:textSize="13sp"
                android:letterSpacing="0.04" />

            <!-- Seminar illustration -->
            <ImageView
                android:layout_width="180dp"
                android:layout_height="80dp"
                android:layout_marginTop="16dp"
                android:src="@drawable/ic_seminar_illustration"
                android:alpha="0.7"
                android:contentDescription="Seminar illustration"
                android:scaleType="fitCenter" />

        </LinearLayout>

        <!-- Bottom card: login form -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.58"
            android:background="@drawable/bg_card_top_rounded"
            android:fillViewport="true"
            android:elevation="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="32dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selamat Datang 👋"
                    android:textColor="#1A237E"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Masuk ke akun Kime Anda"
                    android:textColor="#6B6B8A"
                    android:textSize="14sp" />

                <!-- Divider accent -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="12dp"
                    android:background="#FF8F00" />

                <!-- Email field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/KimeTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:hint="Email"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="@color/kime_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"
                        android:textSize="15sp"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/KimeTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Password"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="@color/kime_primary"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/kime_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:textSize="15sp"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Forgot password -->
                <TextView
                    android:id="@+id/tvForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="10dp"
                    android:text="Lupa password?"
                    android:textColor="#1A237E"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:padding="4dp" />

                <!-- Progress bar -->
                <ProgressBar
                    android:id="@+id/progressLogin"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="8dp"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/kime_primary"
                    android:visibility="gone" />

                <!-- Login button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    style="@style/KimePrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/btn_height"
                    android:layout_marginTop="24dp"
                    android:text="MASUK"
                    android:letterSpacing="0.08" />

                <!-- Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E0E3F5" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="atau"
                        android:textColor="#9898BB"
                        android:textSize="13sp" />
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E0E3F5" />
                </LinearLayout>

                <!-- Register link -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Belum punya akun? "
                        android:textColor="#6B6B8A"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvRegister"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daftar Sekarang"
                        android:textColor="#1A237E"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:padding="4dp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
